generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  name               String?
  role               String              @default("SALESPERSON")
  status             String              @default("PENDING")
  profileData        String?
  aspirations        String?
  availability       String?
  teamId             String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  canCreateBlogs     Boolean             @default(false)
  cedula             String?             @unique
  lastName           String?
  receivePromotions  Boolean             @default(false)
  referredById       String?
  isActive           Boolean             @default(true)
  resetRequested     Boolean             @default(false)
  tempResetCode      String?
  phoneNumber        String?
  profilePicture     String?
  residenceSector    String?
  blogs              Blog[]              @relation("UserBlogs")
  clients            Client[]
  courseEnrollments  CourseEnrollment[]
  receivedEvals      Evaluation[]        @relation("Evaluatee")
  evaluations        Evaluation[]        @relation("Evaluator")
  events             Event[]             @relation("UserEvents")
  receivedMessages   InternalMessage[]   @relation("MessageReceiver")
  sentMessages       InternalMessage[]   @relation("MessageSender")
  jobProfile         JobProfile?         @relation("JobProfile")
  lessonProgress     LessonProgress[]
  notes              Note[]              @relation("UserNotes")
  notifications      Notification[]
  issuedTickets      PaymentTicket[]     @relation("TicketIssuer")
  receivedTickets    PaymentTicket[]     @relation("TicketReceiver")
  phoneRanking       PhoneRanking?
  publicationRanking PublicationRanking?
  quarterlyTasks     QuarterlyTask[]
  conversations      Quote[]
  salesRanking       SalesRanking?
  socialComments     SocialComment[]     @relation("UserComments")
  socialLikes        SocialLike[]        @relation("UserLikes")
  socialPosts        SocialPost[]        @relation("UserPosts")
  socialSettings     SocialSettings?
  socialTags         SocialTag[]         @relation("UserTags")
  StorageFile        StorageFile[]
  transactions       Transaction[]       @relation("UserTransactions")
  referredBy         User?               @relation("UserReferrals", fields: [referredById], references: [id])
  referrals          User[]              @relation("UserReferrals")
  team               Team?               @relation(fields: [teamId], references: [id])
  promptConfigs      UserPromptConfig[]
  waOwnedChats       WAConversation[]    @relation("ConversationOwner")
  webOrders          WebOrder[]          @relation("WebOrderAssignee")
  workCycles         WorkCycle[]
  quarterlyPlans     QuarterlyPlan[]     @relation("AssignedPlans")
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     User[]
}

model Client {
  id               String     @id @default(cuid())
  name             String
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  requirement      String?
  city             String?
  status           String     @default("PROSPECTO")
  source           String     @default("MANUAL")
  lastContact      DateTime   @default(now())
  retargetingCount Int        @default(0)
  campaignsSent    Int        @default(0)
  purchaseCount    Int        @default(0)
  salespersonId    String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  category         String     @default("GENERAL")
  waContactId      String?    @unique
  salesperson      User       @relation(fields: [salespersonId], references: [id])
  waContact        WAContact? @relation(fields: [waContactId], references: [id])
  quotes           Quote[]
}

model Product {
  id             String      @id @default(cuid())
  name           String
  description    String?
  price          Float
  compareAtPrice Float?
  sku            String?     @unique
  categoryId     String?
  collectionId   String?
  images         String?
  specSheetUrl   String?
  keywords       String?
  stock          Int         @default(0)
  isActive       Boolean     @default(true)
  featured       Boolean     @default(false)
  specs          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  isDeleted      Boolean     @default(false)
  provider       String?
  category       Category?   @relation(fields: [categoryId], references: [id])
  collection     Collection? @relation(fields: [collectionId], references: [id])

  @@index([categoryId])
  @@index([collectionId])
  @@index([isDeleted, isActive])
  @@index([provider])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isVisible   Boolean   @default(true)
  image       String?
  pdfUrl      String?
  products    Product[]
}

model Collection {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isVisible   Boolean   @default(true)
  image       String?
  pdfUrl      String?
  products    Product[]
}

model Quote {
  id                String   @id @default(cuid())
  quoteNumber       String   @unique
  clientId          String
  salespersonId     String
  subtotal          Float
  tax               Float
  discount          Float    @default(0)
  total             Float
  pdfUrl            String?
  status            String   @default("DRAFT")
  warrantyComments  String?
  deliveryAddress   String?
  clientName        String?
  discountPercent   Float    @default(0)
  itemsData         String?
  globalQuoteNumber String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  advisorName       String?
  client            Client   @relation(fields: [clientId], references: [id])
  salesperson       User     @relation(fields: [salespersonId], references: [id])
}

model WebOrder {
  id                    String   @id @default(cuid())
  orderNumber           String   @unique
  customerName          String
  customerEmail         String
  customerPhone         String?
  companyName           String?
  status                String   @default("NUEVO")
  itemsData             String
  totalAmount           Float
  notes                 String?
  assignedSalespersonId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  assignedSalesperson   User?    @relation("WebOrderAssignee", fields: [assignedSalespersonId], references: [id])
}

model Transaction {
  id            String   @id @default(cuid())
  trxId         String   @unique
  client        String
  date          DateTime @default(now())
  amount        Float
  cost          Float    @default(0)
  profit        Float    @default(0)
  commission    Float    @default(0)
  status        String   @default("PENDIENTE")
  type          String   @default("Venta Directa")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  salespersonId String?
  proofUrl      String?
  pvp           Float    @default(0)
  bonus         Float    @default(0)
  quoteNumber   String?
  salesperson   User?    @relation("UserTransactions", fields: [salespersonId], references: [id])
}

model Evaluation {
  id           String   @id @default(cuid())
  evaluatorId  String
  evaluateeId  String
  score        Float
  rubricData   String
  observations String?
  cycleDay     Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  evaluatee    User     @relation("Evaluatee", fields: [evaluateeId], references: [id])
  evaluator    User     @relation("Evaluator", fields: [evaluatorId], references: [id])
}

model WorkCycle {
  id            String     @id @default(cuid())
  userId        String
  role          String
  startDate     DateTime?
  endDate       DateTime?
  fixedPay      Float?
  commissionPct Float?
  functions     String     @default("[]")
  isActive      Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  contractUrl   String?
  dailyLogs     DailyLog[]
  user          User       @relation(fields: [userId], references: [id])
}

model DailyLog {
  id        String    @id @default(cuid())
  cycleId   String
  dayNumber Int
  date      DateTime  @default(now())
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  cycle     WorkCycle @relation(fields: [cycleId], references: [id])
}

model ExtractionTemplate {
  id        String   @id @default(cuid())
  domain    String   @unique
  name      String?
  selectors String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExtractionHistory {
  id           String   @id @default(cuid())
  url          String
  domain       String
  status       String   @default("PENDING")
  itemCount    Int      @default(0)
  errorMessage String?
  exportUrl    String?
  createdAt    DateTime @default(now())
}

model WAContact {
  id            String           @id @default(cuid())
  whatsappId    String           @unique
  name          String?
  profilePic    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  client        Client?
  conversations WAConversation[]

  @@index([whatsappId])
}

model WAConversation {
  id            String         @id @default(cuid())
  contactId     String
  status        String         @default("NEW")
  priority      String         @default("MEDIUM")
  ownerId       String?
  lastMessageAt DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  assignments   WAAssignment[]
  contact       WAContact      @relation(fields: [contactId], references: [id])
  owner         User?          @relation("ConversationOwner", fields: [ownerId], references: [id])
  messages      WAMessage[]
  notes         WANote[]
  tags          WATag[]        @relation("WAConversationToWATag")

  @@index([status])
  @@index([contactId])
}

model WAMessage {
  id                String         @id @default(cuid())
  conversationId    String
  whatsappMessageId String?        @unique
  direction         String
  type              String         @default("text")
  body              String?        @default("")
  mediaUrl          String?
  status            String         @default("SENT")
  errorMessage      String?
  senderId          String?
  createdAt         DateTime       @default(now())
  conversation      WAConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([direction])
}

model WATag {
  id            String           @id @default(cuid())
  name          String           @unique
  color         String?          @default("#FF5733")
  conversations WAConversation[] @relation("WAConversationToWATag")
}

model WANote {
  id             String         @id @default(cuid())
  conversationId String
  authorId       String
  content        String
  createdAt      DateTime       @default(now())
  conversation   WAConversation @relation(fields: [conversationId], references: [id])
}

model WAAssignment {
  id              String         @id @default(cuid())
  conversationId  String
  assignerId      String?
  assigneeId      String
  previousOwnerId String?
  createdAt       DateTime       @default(now())
  conversation    WAConversation @relation(fields: [conversationId], references: [id])
}

model WATemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String?
  language  String   @default("es")
  content   String
  status    String   @default("APPROVED")
  createdAt DateTime @default(now())
}

model StorageFolder {
  id         String          @id @default(cuid())
  name       String
  parentId   String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  files      StorageFile[]
  parent     StorageFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  subfolders StorageFolder[] @relation("FolderHierarchy")
}

model StorageFile {
  id         String         @id @default(cuid())
  name       String
  url        String
  size       Int            @default(0)
  folderId   String?
  uploaderId String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  folder     StorageFolder? @relation(fields: [folderId], references: [id])
  uploader   User           @relation(fields: [uploaderId], references: [id])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model InternalMessage {
  id         String   @id @default(cuid())
  subject    String
  type       String   @default("Mensaje Simple")
  content    String
  status     String   @default("Recibido")
  isRead     Boolean  @default(false)
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  color     String?
  pinned    Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("UserNotes", fields: [userId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  start       DateTime
  end         DateTime
  color       String?
  allDay      Boolean  @default(false)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("UserEvents", fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  relatedId String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model PaymentTicket {
  id        String   @id @default(cuid())
  issueDate DateTime @default(now())
  dueDate   DateTime
  amount    Float
  concept   String
  status    String   @default("PENDING")
  adminId   String
  advisorId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     User     @relation("TicketIssuer", fields: [adminId], references: [id])
  advisor   User     @relation("TicketReceiver", fields: [advisorId], references: [id])
}

model UserPromptConfig {
  id        String   @id @default(cuid())
  userId    String
  type      String
  prompt    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model SavedPrompt {
  id        String   @id @default(cuid())
  name      String
  type      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Blog {
  id             String       @id @default(cuid())
  title          String
  excerpt        String?
  content        String
  imageUrl       String?
  published      Boolean      @default(false)
  authorId       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  contentType    String       @default("article")
  publishResults String?
  socialTargets  String?
  videoUrl       String?
  environmentId  String?
  targetAccounts String?
  author         User         @relation("UserBlogs", fields: [authorId], references: [id])
  environment    Environment? @relation(fields: [environmentId], references: [id])
}

model Environment {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  blogs       Blog[]
  accounts    SocialAccount[]
}

model SocialAccount {
  id            String      @id @default(cuid())
  name          String
  platform      String
  externalId    String?
  environmentId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  environment   Environment @relation(fields: [environmentId], references: [id])
}

model SocialSettings {
  id                  String   @id @default(cuid())
  metaPageId          String?
  metaPageToken       String?
  metaInstagramActId  String?
  youtubeChannelId    String?
  youtubeRefreshToken String?
  tiktokAccessToken   String?
  tiktokOpenId        String?
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
  userId              String?  @unique
  user                User?    @relation(fields: [userId], references: [id])
}

model SocialPost {
  id        String          @id @default(cuid())
  content   String?
  mediaUrls String?
  authorId  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  comments  SocialComment[]
  likes     SocialLike[]
  author    User            @relation("UserPosts", fields: [authorId], references: [id])
  tags      SocialTag[]
}

model SocialComment {
  id        String     @id @default(cuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  author    User       @relation("UserComments", fields: [authorId], references: [id])
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model SocialLike {
  id        String     @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime   @default(now())
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User       @relation("UserLikes", fields: [userId], references: [id])

  @@unique([postId, userId])
}

model SocialTag {
  id     String     @id @default(cuid())
  postId String
  userId String
  post   SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User       @relation("UserTags", fields: [userId], references: [id])

  @@unique([postId, userId])
}

model QuarterlyPlan {
  id                    String          @id @default(cuid())
  name                  String
  objective             String?
  participants          String?
  notifyUsers           Boolean         @default(false)
  postsPerDay           Int             @default(3)
  retargetingPerWeek    Int             @default(1)
  leadsPerWeek          Int             @default(25)
  adminMeetingsPerWeek  Int             @default(1)
  adminProvideDbPerWeek Int             @default(5)
  status                String          @default("ACTIVO")
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  tasks                 QuarterlyTask[]
  assignedUsers         User[]          @relation("AssignedPlans")
}

model QuarterlyTask {
  id        String        @id @default(cuid())
  planId    String
  userId    String
  type      String
  week      Int
  day       Int?
  content   String?
  count     Int           @default(0)
  required  Int           @default(0)
  status    String        @default("PENDING")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  plan      QuarterlyPlan @relation(fields: [planId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
}

model JobProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  title            String
  description      String?
  skills           String?
  responsibilities String?
  benefits         String?
  templateName     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation("JobProfile", fields: [userId], references: [id])
}

model AcademyCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  courses     Course[]
}

model Course {
  id          String             @id @default(cuid())
  title       String
  slug        String             @unique
  description String?
  imageUrl    String?
  categoryId  String
  published   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  category    AcademyCategory    @relation(fields: [categoryId], references: [id])
  enrollments CourseEnrollment[]
  lessons     Lesson[]
}

model Lesson {
  id        String           @id @default(cuid())
  title     String
  slug      String
  content   String
  videoUrl  String?
  order     Int              @default(0)
  courseId  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  quizData  String?
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress  LessonProgress[]

  @@unique([courseId, slug])
}

model CourseEnrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  status      String    @default("IN_PROGRESS")
  progress    Int       @default(0)
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LessonProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model SalesRanking {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentWeekAmount Float    @default(0)
  historicalAmount  Float    @default(0)
  lastReset         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SalesWeeklyGoal {
  id          String   @id @default(cuid())
  amount      Float    @default(0)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PhoneRanking {
  id               String   @id @default(cuid())
  userId           String   @unique
  currentWeekCount Int      @default(0)
  historicalCount  Int      @default(0)
  lastReset        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeeklyGoal {
  id          String   @id @default(cuid())
  amount      Float    @default(0)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PublicationRanking {
  id               String   @id @default(cuid())
  userId           String   @unique
  currentWeekCount Int      @default(0)
  historicalCount  Int      @default(0)
  lastReset        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PublicationWeeklyGoal {
  id          String   @id @default(cuid())
  amount      Float    @default(0)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
